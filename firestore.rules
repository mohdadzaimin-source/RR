rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOfficialAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             request.auth.token.email.lower() in [
               'izarul@risda.gov.my', 
               'adzaimin@risda.gov.my',
               'syahrul.nizam@risda.gov.my', 
               'sulizah@risda.gov.my', 
               'ira@risda.gov.my', 
               'mohdadzaimin@gmail.com',
               'mohdadzaimin@googlemail.com'
             ];
    }

    function isAdmin() {
      return isOfficialAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Requests collection
    match /requests/{requestId} {
      // Allow public read and creation since the portal allows guest tracking by email
      allow read: if true;
      allow list: if true;
      allow get: if true;
      
      allow create: if isValidId(requestId) &&
                      incoming().userEmail != null &&
                      incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && 
                      (
                        // Admin or role-based update
                        (isAdmin() && (
                          incoming().diff(existing()).affectedKeys().hasOnly(['data', 'updatedAt']) ||
                          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
                        )) ||
                        // Driver update (simplified check)
                        (incoming().diff(existing()).affectedKeys().hasOnly(['data', 'updatedAt']) && 
                         incoming().data.status_kelulusan.pemandu != existing().data.status_kelulusan.pemandu) ||
                        // Owner update (If they were logged in when creating)
                        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['data', 'updatedAt']))
                      ) &&
                      incoming().updatedAt == request.time;
                      
      allow delete: if isAdmin();
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && 
                     adminId == request.auth.uid && 
                     (isOfficialAdmin() || 
                      request.auth.token.email.lower() == 'mohdadzaimin@gmail.com' || 
                      request.auth.token.email.lower() == 'mohdadzaimin@googlemail.com');
    }
  }
}
